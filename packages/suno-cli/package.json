{
	"name": "@yabbal/suno-cli",
	"version": "2.0.0",
	"description": "CLI for Suno",
	"type": "module",
	"bin": {
		"suno": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "pnpm build",
		"release": "changeset publish"
	},
	"keywords": [],
	"author": "yabbal",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yabbal/suno.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/yabbal/suno#readme",
	"bugs": {
		"url": "https://github.com/yabbal/suno/issues"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"citty": "^0.2.1",
		"cli-table3": "^0.6.5",
		"consola": "^3.4.2",
		"@yabbal/suno-sdk": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.5",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
